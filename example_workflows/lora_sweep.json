{
  "name": "foley_lora_sweep",
  "data_dir": "/path/to/augmented/features",
  "output_root": "/path/to/lora_output/sweep",
  "base": {
    "target": "all_attn_mlp",
    "rank": 64,
    "alpha": 64,
    "lr": 1e-4,
    "steps": 5000,
    "batch_size": 8,
    "grad_accum": 1,
    "warmup_steps": 100,
    "save_every": 500,
    "timestep_mode": "logit_normal",
    "precision": "bf16",
    "seed": 42
  },
  "experiments": [
    {
      "id": "baseline_r64",
      "_comment": "Default settings — rank 64, all_attn_mlp, logit_normal"
    },
    {
      "id": "rank32",
      "_comment": "Lower capacity — might underfit with 128D latent",
      "rank": 32,
      "alpha": 32
    },
    {
      "id": "rank128",
      "_comment": "Higher capacity — good for ~99 clips, watch for overfitting",
      "rank": 128,
      "alpha": 128
    },
    {
      "id": "loraplus_r64",
      "_comment": "LoRA+ — 16x LR on B matrix, faster convergence",
      "lora_plus_ratio": 16.0
    },
    {
      "id": "audio_cross_r64",
      "_comment": "Fewer target layers — less capacity but more focused",
      "target": "audio_cross"
    },
    {
      "id": "cosine_lr",
      "_comment": "Cosine decay — may converge tighter than constant",
      "schedule_type": "cosine",
      "steps": 6000
    }
  ]
}
